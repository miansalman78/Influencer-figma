# ============================================
# API CONFIGURATION
# ============================================

# Backend API Base URL (used if react-native-config is installed)
# For physical device over USB: use your PC's IP so the phone can reach the backend.
# Example: API_BASE_URL=http://192.168.1.5:5000/api
# Find your IP: ipconfig (Windows) or ifconfig (Mac/Linux)
API_BASE_URL=https://adpartnr.onrender.com/api

# API Timeout (milliseconds)
API_TIMEOUT=60000

# ============================================
# APP CONFIGURATION
# ============================================

# App Environment (development, staging, production)
ENV=production

# App Name
APP_NAME=InfluencerNative

# App Version
APP_VERSION=1.0.0

# Support user ID for "Chat with support" (Help & Support). Must be a valid user ID in your DB/Firestore.
# Leave empty to hide the in-app support chat; users can still use "Email support" instead.
# SUPPORT_USER_ID=

# ============================================
# FIREBASE CONFIGURATION (for Messaging)
# ============================================
# Note: Firebase config is in google-services.json (Android) and GoogleService-Info.plist (iOS)
# No environment variables needed for Firebase

# ============================================
# CLOUDINARY CONFIGURATION (for Image Uploads)
# ============================================
# Note: Cloudinary is configured on backend, not frontend
# No environment variables needed for frontend

# ============================================
# FEATURE FLAGS
# ============================================

# Enable Analytics
ENABLE_ANALYTICS=false

# Enable Crash Reporting
ENABLE_CRASH_REPORTING=false

# Enable Offline Mode
ENABLE_OFFLINE_MODE=false

# Enable Debug Mode
ENABLE_DEBUG_MODE=false

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Session Timeout (milliseconds) - 1 hour
SESSION_TIMEOUT=3600000

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=error

# Enable Console Logs
ENABLE_CONSOLE_LOGS=false

# Enable Remote Logging
ENABLE_REMOTE_LOGGING=false
