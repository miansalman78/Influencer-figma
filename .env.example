# ============================================
# API CONFIGURATION
# ============================================

# Backend API Base URL (local backend for testing)
API_BASE_URL=https://adpartnr.onrender.com/api
#API_BASE_URL=http://10.206.71.114:5000/api
# API Timeout (milliseconds)
API_TIMEOUT=60000

# ============================================
# APP CONFIGURATION
# ============================================

# Use development API in development
FORCE_PRODUCTION= true

# App Name
APP_NAME= Adpartnr

# App Version
APP_VERSION=1.0.0

# ============================================
# FIREBASE CONFIGURATION (for Messaging)
# ============================================
# Note: Firebase config is in google-services.json (Android) and GoogleService-Info.plist (iOS)
# No environment variables needed for Firebase

# ============================================
# CLOUDINARY CONFIGURATION (for Image Uploads)
# ============================================
# Note: Cloudinary is configured on backend, not frontend
# No environment variables needed for frontend

# ============================================
# FEATURE FLAGS
# ============================================

# Enable Analytics
ENABLE_ANALYTICS=false

# Enable Crash Reporting
ENABLE_CRASH_REPORTING=false

# Enable Offline Mode
ENABLE_OFFLINE_MODE=false

# Enable Debug Mode
ENABLE_DEBUG_MODE=false

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Session Timeout (milliseconds) - 1 hour
SESSION_TIMEOUT=3600000

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=error

# Enable Console Logs
ENABLE_CONSOLE_LOGS=false

# Enable Remote Logging
ENABLE_REMOTE_LOGGING=false