# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/adpartnr

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_SECRET_HASH=your_flutterwave_secret_hash  # Get from Flutterwave Dashboard > Settings > Security

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_xxxxx  # Get from Stripe Dashboard > Webhooks

# PayPal (Sandbox: https://developer.paypal.com/dashboard/applications/sandbox)
# Copy these into .env - API Key = Client ID, Secret = Client Secret
# If you get PAYEE_ACCOUNT_RESTRICTED: log in at https://sandbox.paypal.com with your sandbox *business* account and complete any verification/onboarding.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Social Media APIs (OAuth)
# Note: Instagram Graph API uses Facebook App credentials
# INSTAGRAM_APP_ID and INSTAGRAM_APP_SECRET are no longer used (Basic Display API deprecated)
# Use FACEBOOK_APP_ID and FACEBOOK_APP_SECRET for Instagram Graph API
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Google OAuth (for Sign in with Google)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth (for Sign in with Apple)
# Get from: https://developer.apple.com/account/resources/identifiers/list
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
# Apple Private Key (PEM format) - Keep this secure!
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Meta Business Configuration ID (required for Facebook Login for Business)
# Get this from: App Dashboard > Facebook Login for Business > Configurations
# This is required to use Facebook Login for Business OAuth flow
META_BUSINESS_CONFIGURATION_ID=your_business_configuration_id

# Email Configuration (for password reset)
EMAIL_HOST=adsbarter.com
EMAIL_PORT=587
EMAIL_USER=notify@adsbarter.com
EMAIL_PASS=your_email_password
EMAIL_SECURE=false

# Backend URL (for OAuth redirect URIs - defaults to auto-detect from request)
# IMPORTANT: Facebook and Instagram require HTTPS for all OAuth redirect URIs (except localhost)
# For production, use HTTPS: BACKEND_URL=https://yourdomain.com
# For local development, use HTTP: BACKEND_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000

# Frontend URL (for password reset, OAuth, and PayPal return/cancel URLs - no trailing slash)
# For production: FRONTEND_URL=https://adpartnr-frontend.onrender.com
# For local development: FRONTEND_URL=http://localhost:3000
FRONTEND_URL=https://adpartnr-frontend.onrender.com

# Social Media Sync Job
# Cron schedule for automatic social media metrics sync (default: every 3 hours)
# Format: minute hour day month day-of-week
# Examples:
#   '0 */3 * * *' = every 3 hours (default)
#   '0 */6 * * *' = every 6 hours
#   '0 0 * * *' = daily at midnight
#   '0 */12 * * *' = every 12 hours
SOCIAL_SYNC_SCHEDULE=0 */3 * * *

# Token Refresh Job
# Cron schedule for dedicated token refresh job (default: every hour)
# This job only refreshes tokens, doesn't fetch metrics
# Format: minute hour day month day-of-week
# Examples:
#   '0 * * * *' = every hour (default)
#   '0 */2 * * *' = every 2 hours
#   '*/30 * * * *' = every 30 minutes
TOKEN_REFRESH_SCHEDULE=0 * * * *

# Bright Data (social scraping during onboarding)
# Super Proxy: Instagram, Facebook, Twitter. Get from Bright Data dashboard > Proxy > Overview.
BRIGHTDATA_CUSTOMER=your_customer_id
BRIGHTDATA_ZONE=your_zone_name
BRIGHTDATA_PASSWORD=your_zone_password
# Optional: for HTTPS to proxy (port 33335). Download CA from https://brightdata.com/static/brightdata_proxy_ca.zip
BRIGHTDATA_CERT_PATH=

# TikTok: Web Scrapers Library (Datasets API). Scrapers > tiktok.com > TikTok - Profiles > Collect by URL.
# Use dataset_id from the scraper page and Bearer token from the dashboard.
# Average response time per input is ~25s (Bright Data loads the page in a browser). Price ~$0.0015/record.
BRIGHTDATA_DATASETS_API_KEY=
BRIGHTDATA_TIKTOK_DATASET_ID=
# Optional: max wait in ms for TikTok scrape (default 45000). Increase if you see timeouts.
# BRIGHTDATA_TIKTOK_TIMEOUT_MS=45000

# Twitter/X: Web Scrapers Library (same Datasets API). Scrapers > x.com or twitter.com > Twitter - Profiles (or similar).
# When set, Twitter follower scrape uses this instead of Super Proxy (more reliable for JS-rendered X pages).
BRIGHTDATA_TWITTER_DATASET_ID=
# Optional: max wait in ms for Twitter scrape (default 45000).
# BRIGHTDATA_TWITTER_TIMEOUT_MS=45000

# Currency Conversion Feature
# Enable or disable currency conversion at withdrawal time
# Set to 'true' or '1' to enable, 'false' or '0' to disable
# When enabled, creators can withdraw to payment methods with different currencies (conversion with fee applied)
# When disabled, creators can only withdraw to payment methods matching their wallet currency
ENABLE_CURRENCY_CONVERSION=true
